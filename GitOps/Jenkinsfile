@Library('Shared') _

pipeline {
    agent any

    parameters {
        string(name: 'FRONTEND_DOCKER_TAG', defaultValue: '', description: 'Frontend Docker image tag')
        string(name: 'BACKEND_DOCKER_TAG', defaultValue: '', description: 'Backend Docker image tag')
    }

    stages {

        stage('Workspace Cleanup') {
            steps {
                cleanWs()
            }
        }

        stage('Git: Code Checkout') {
            steps {
                script {
                    code_checkout("https://github.com/pawanpatil123/devsecops_with_gitops-.git", "main")
                }
            }
        }

        stage('Verify Docker Image Tags') {
            steps {
                echo "Frontend Image Tag : ${params.FRONTEND_DOCKER_TAG}"
                echo "Backend Image Tag  : ${params.BACKEND_DOCKER_TAG}"
            }
        }

        stage('Update Kubernetes Manifests') {
            steps {
                dir('kubernetes') {
                    sh """
                    echo "Updating backend deployment..."
                    sed -i 's|image: .*wanderlust-backend-beta:.*|image: piyushpatil44099/wanderlust-backend-beta:${params.BACKEND_DOCKER_TAG}|' backend.yaml

                    echo "Updating frontend deployment..."
                    sed -i 's|image: .*wanderlust-frontend-beta:.*|image: piyushpatil44099/wanderlust-frontend-beta:${params.FRONTEND_DOCKER_TAG}|' frontend.yaml

                    echo "Updated image tags:"
                    grep "image:" backend.yaml
                    grep "image:" frontend.yaml
                    """
                }
            }
        }

        stage('Git: Commit & Push Changes') {
            steps {
                script {
                    withCredentials([
                        gitUsernamePassword(
                            credentialsId: 'Github-cred',
                            gitToolName: 'Default'
                        )
                    ]) {

                        sh '''
                        echo "==========================="
                        echo "Repository Status"
                        echo "==========================="
                        git status

                        echo "==========================="
                        echo "Adding Changes"
                        echo "==========================="
                        git add .

                        echo "==========================="
                        echo "Git Diff"
                        echo "==========================="
                        git diff --cached

                        if git diff --cached --quiet
                        then
                            echo "No changes detected."
                            echo "Skipping Git Commit and Push."
                        else
                            echo "Changes detected."

                            git config user.name "Jenkins"
                            git config user.email "jenkins@local"

                            git commit -m "Updated Kubernetes manifests"

                            git push origin main

                            echo "Git Push Successful."
                        fi
                        '''
                    }
                }
            }
        }
    }

    // post {

    //     success {
    //         emailext(
    //             attachLog: true,
    //             from: 'piyushpatil44099@gmail.com',
    //             to: 'piyushpatil1252@gmail.com',
    //             mimeType: 'text/html',
    //             subject: "SUCCESS : ${env.JOB_NAME} #${env.BUILD_NUMBER}",
    //             body: """
    //             <html>
    //             <body>
    //             <h2 style="color:green;">Deployment Successful</h2>

    //             <table border="1" cellpadding="8">
    //                 <tr>
    //                     <th>Project</th>
    //                     <td>${env.JOB_NAME}</td>
    //                 </tr>

    //                 <tr>
    //                     <th>Build Number</th>
    //                     <td>${env.BUILD_NUMBER}</td>
    //                 </tr>

    //                 <tr>
    //                     <th>Frontend Tag</th>
    //                     <td>${params.FRONTEND_DOCKER_TAG}</td>
    //                 </tr>

    //                 <tr>
    //                     <th>Backend Tag</th>
    //                     <td>${params.BACKEND_DOCKER_TAG}</td>
    //                 </tr>

    //                 <tr>
    //                     <th>Build URL</th>
    //                     <td>${env.BUILD_URL}</td>
    //                 </tr>
    //             </table>

    //             </body>
    //             </html>
    //             """
    //         )
    //     }

    //     failure {
    //         emailext(
    //             attachLog: true,
    //             from: 'piyushpatil44099@gmail.com',
    //             to: 'piyushpatil1252@gmail.com',
    //             mimeType: 'text/html',
    //             subject: "FAILED : ${env.JOB_NAME} #${env.BUILD_NUMBER}",
    //             body: """
    //             <html>
    //             <body>

    //             <h2 style="color:red;">Deployment Failed</h2>

    //             <table border="1" cellpadding="8">
    //                 <tr>
    //                     <th>Project</th>
    //                     <td>${env.JOB_NAME}</td>
    //                 </tr>

    //                 <tr>
    //                     <th>Build Number</th>
    //                     <td>${env.BUILD_NUMBER}</td>
    //                 </tr>

    //                 <tr>
    //                     <th>Build URL</th>
    //                     <td>${env.BUILD_URL}</td>
    //                 </tr>

    //             </table>

    //             </body>
    //             </html>
    //             """
    //         )
    //     }
    // }

post {

    success {
        emailext(
            to: 'piyushpatil1252@gmail.com',
            recipientProviders: [requestor()],
            subject: "SUCCESS: ${env.JOB_NAME} #${env.BUILD_NUMBER}",
            mimeType: 'text/plain',
            attachLog: true,
            body: """
Build Status : SUCCESS

Project      : ${env.JOB_NAME}
Build Number : ${env.BUILD_NUMBER}

Frontend Tag : ${params.FRONTEND_DOCKER_TAG}
Backend Tag  : ${params.BACKEND_DOCKER_TAG}

Build URL:
${env.BUILD_URL}
"""
        )
    }

    failure {
        emailext(
            to: 'piyushpatil1252@gmail.com',
            recipientProviders: [requestor()],
            subject: "FAILED: ${env.JOB_NAME} #${env.BUILD_NUMBER}",
            mimeType: 'text/plain',
            attachLog: true,
            body: """
Build Status : FAILED

Project      : ${env.JOB_NAME}
Build Number : ${env.BUILD_NUMBER}

Build URL:
${env.BUILD_URL}

Please check the attached console log.
"""
        )
    }

    always {
        echo "Pipeline Finished."
    }
}

}